SECRET_KEY=change-this-to-a-very-secret-random-string
DATABASE_URL=mysql+pymysql://root:your_password@localhost/eventorydb

# Flask-Mail
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password

# Super Admin
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=YourSuperAdminPassword

# App base URL (no trailing slash)
APP_BASE_URL=http://localhost:5000

# Paystack (get keys from https://dashboard.paystack.com/#/settings/developers)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Billing currency — Paystack supports USD, NGN, GHS, ZAR, KES
PAYSTACK_CURRENCY=USD
